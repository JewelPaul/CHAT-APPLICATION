{
  "name": "chatwave",
  "version": "2.0.0",
  "type": "commonjs",
  "description": "Ephemeral, invite-based secure chat application",
  "main": "server/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server/server.js",
    "dev": "concurrently \"nodemon server/server.js\" \"cd client && npm run dev\"",
    "dev:server": "nodemon server/server.js",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "lint": "eslint server/ --fix && cd client && npm run lint",
    "format": "prettier --write server/ && cd client && prettier --write src/",
    "health": "curl -s http://localhost:3000/health | jq ."
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.5.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^9.30.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1"
  },
  "keywords": [
    "chat",
    "ephemeral",
    "secure",
    "real-time",
    "invite-based",
    "react",
    "typescript",
    "tailwindcss"
  ],
  "author": "JewelPaul",
  "license": "MIT"
}
